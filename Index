<style>
  :root{
    --bg:#170D12;
    --bg-alt:#1D1017;
    --surface:#26141D;
    --surface-2:#301A26;
    --border:rgba(201,162,76,0.16);
    --border-strong:rgba(201,162,76,0.36);
    --gold:#C9A24C;
    --gold-light:#E3C687;
    --gold-dim:#8A6F35;
    --rose:#B14B5C;
    --rose-light:#D98A93;
    --ink:#F5EAE0;
    --ink-soft:#C6B3A7;
    --ink-faint:#8C7A70;
    --shadow:0 24px 60px rgba(0,0,0,0.45);
    --radius-sm:10px;
    --radius-md:18px;
    --radius-lg:30px;
    --font-display:'Cormorant Garamond', serif;
    --font-body:'Inter', sans-serif;
    --container:1180px;
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth; font-size:17px;}
  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:0.001ms !important; animation-iteration-count:1 !important; transition-duration:0.001ms !important;}
  }
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:var(--font-body);
    line-height:1.7;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  img,svg{display:block; max-width:100%;}
  a{color:inherit; text-decoration:none;}
  ul{margin:0; padding:0; list-style:none;}
  h1,h2,h3,h4{margin:0; font-family:var(--font-display); font-weight:600; color:var(--ink); letter-spacing:0.01em;}
  p{margin:0;}
  .container{max-width:var(--container); margin:0 auto; padding:0 28px;}
  .icon{width:1em; height:1em; stroke:currentColor; fill:none; stroke-width:1.6; stroke-linecap:round; stroke-linejoin:round;}
  .icon.filled{fill:currentColor; stroke:none;}

  section{position:relative; padding:112px 0;}
  @media (max-width:720px){ section{padding:72px 0;} }

  .eyebrow{
    display:inline-flex; align-items:center; gap:10px;
    font-family:var(--font-body); font-size:0.82rem; font-weight:600;
    letter-spacing:0.16em; text-transform:uppercase; color:var(--gold-light);
    margin-bottom:18px;
  }
  .eyebrow .glyph{width:9px; height:9px; background:var(--gold); transform:rotate(45deg); flex:none;}

  .section-head{max-width:640px; margin-bottom:56px;}
  .section-head.center{margin-left:auto; margin-right:auto; text-align:center;}
  .section-head h2{font-size:clamp(1.9rem, 2.6vw + 1rem, 2.9rem); line-height:1.15;}
  .section-head p{margin-top:16px; color:var(--ink-soft); font-size:1.03rem;}

  /* ---------- Buttons ---------- */
  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:10px;
    padding:15px 30px; border-radius:100px; font-family:var(--font-body);
    font-weight:600; font-size:0.95rem; letter-spacing:0.02em; cursor:pointer;
    border:1px solid transparent; transition:transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease;
    white-space:nowrap;
  }
  .btn .icon{width:17px; height:17px;}
  .btn-primary{background:linear-gradient(135deg, var(--gold-light), var(--gold)); color:#1A1009;}
  .btn-primary:hover{transform:translateY(-2px); box-shadow:0 14px 30px rgba(201,162,76,0.28);}
  .btn-outline{background:transparent; color:var(--gold-light); border-color:var(--border-strong);}
  .btn-outline:hover{border-color:var(--gold); background:rgba(201,162,76,0.08); transform:translateY(-2px);}
  .btn-sm{padding:10px 20px; font-size:0.85rem;}

  /* ---------- Header ---------- */
  header{
    position:fixed; top:0; left:0; right:0; z-index:100;
    background:rgba(23,13,18,0.82); backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
    border-bottom:1px solid var(--border);
  }
  .nav-wrap{display:flex; align-items:center; justify-content:space-between; padding:18px 28px;}
  .logo{display:flex; align-items:center; gap:10px; font-family:var(--font-display); font-weight:600; font-size:1.3rem; color:var(--ink);}
  .logo .mark{width:30px; height:30px; color:var(--gold);}
  .logo .brand-sub{display:block; font-family:var(--font-body); font-size:0.62rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-faint); font-weight:600; margin-top:2px;}
  nav.links{display:flex; align-items:center; gap:34px;}
  nav.links a{font-size:0.88rem; font-weight:500; color:var(--ink-soft); transition:color .2s ease; position:relative;}
  nav.links a:hover{color:var(--gold-light);}
  .nav-actions{display:flex; align-items:center; gap:14px;}
  .hamburger{display:none; flex-direction:column; gap:5px; background:none; border:none; cursor:pointer; padding:6px;}
  .hamburger span{width:22px; height:2px; background:var(--gold-light); display:block; transition:transform .25s ease, opacity .25s ease;}
  .mobile-panel{display:none; flex-direction:column; gap:2px; background:var(--bg-alt); border-top:1px solid var(--border); padding:8px 28px 20px;}
  .mobile-panel a{padding:12px 0; font-size:0.98rem; color:var(--ink-soft); border-bottom:1px solid var(--border);}
  .mobile-panel.open{display:flex;}

  @media (max-width:960px){
    nav.links{display:none;}
    .nav-actions .btn-outline{display:none;}
    .hamburger{display:flex;}
  }

  /* ---------- Hero ---------- */
  .hero{padding-top:168px; padding-bottom:110px; overflow:hidden;}
  .hero-bg-glow{position:absolute; inset:0; z-index:0; pointer-events:none;
    background:
      radial-gradient(560px 420px at 82% 10%, rgba(177,75,92,0.18), transparent 65%),
      radial-gradient(520px 420px at 8% 90%, rgba(201,162,76,0.12), transparent 65%);
  }
  .hero-stars{position:absolute; inset:0; z-index:0; opacity:0.5; pointer-events:none;
    background-image:
      radial-gradient(1.5px 1.5px at 20% 30%, var(--gold-light) 40%, transparent 41%),
      radial-gradient(1.5px 1.5px at 70% 15%, var(--gold-light) 40%, transparent 41%),
      radial-gradient(1px 1px at 40% 70%, var(--ink-soft) 40%, transparent 41%),
      radial-gradient(1.5px 1.5px at 88% 60%, var(--gold-light) 40%, transparent 41%),
      radial-gradient(1px 1px at 55% 40%, var(--ink-soft) 40%, transparent 41%),
      radial-gradient(1.5px 1.5px at 12% 65%, var(--gold-light) 40%, transparent 41%);
  }
  .hero-grid{position:relative; z-index:1; display:grid; grid-template-columns:1.05fr 0.95fr; gap:50px; align-items:center;}
  .hero h1{font-size:clamp(2.3rem, 3.2vw + 1rem, 3.6rem); line-height:1.12; font-weight:600;}
  .hero h1 em{font-style:italic; color:var(--gold-light); font-weight:600;}
  .hero-sub{margin-top:24px; font-size:1.08rem; color:var(--ink-soft); max-width:520px;}
  .hero-ctas{display:flex; gap:16px; margin-top:36px; flex-wrap:wrap;}
  .trust-strip{display:flex; gap:28px; margin-top:48px; flex-wrap:wrap;}
  .trust-item{display:flex; flex-direction:column; gap:2px;}
  .trust-item .num{font-family:var(--font-display); font-size:1.7rem; font-weight:600; color:var(--gold-light);}
  .trust-item .lbl{font-size:0.78rem; color:var(--ink-faint); letter-spacing:0.04em;}

  .hero-visual{position:relative; display:flex; align-items:center; justify-content:center;}
  .kundali-wrap{position:relative; width:100%; max-width:440px;}
  .kundali-wrap svg{width:100%; height:auto;}
  .twinkle{animation:twinkle 3.6s ease-in-out infinite;}
  @keyframes twinkle{0%,100%{opacity:0.25;} 50%{opacity:1;}}
  .spin-slow{animation:spin 90s linear infinite; transform-origin:220px 220px;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .pulse-glow{animation:pulseGlow 2.8s ease-in-out infinite;}
  @keyframes pulseGlow{0%,100%{opacity:0.55; transform:scale(1);} 50%{opacity:1; transform:scale(1.12);}}

  @media (max-width:900px){
    .hero-grid{grid-template-columns:1fr; text-align:left;}
    .hero-visual{order:2; margin-top:30px; max-width:340px; margin-left:auto; margin-right:auto;}
    .hero{padding-top:140px;}
  }

  /* ---------- About ---------- */
  .about-grid{display:grid; grid-template-columns:0.85fr 1.15fr; gap:64px; align-items:center;}
  .about-frame{position:relative; aspect-ratio:4/5; border-radius:var(--radius-lg); background:linear-gradient(155deg, var(--surface-2), var(--surface)); border:1px solid var(--border-strong); display:flex; align-items:center; justify-content:center; overflow:hidden;}
  .about-frame::before{content:""; position:absolute; inset:14px; border:1px solid var(--border); border-radius:calc(var(--radius-lg) - 10px);}
  .about-frame .glyph-big{width:38%; color:var(--gold); opacity:0.85;}
  .about-copy p{color:var(--ink-soft); margin-bottom:18px; font-size:1.02rem;}
  .credential-chips{display:flex; flex-wrap:wrap; gap:12px; margin-top:28px;}
  .chip{display:inline-flex; align-items:center; gap:8px; padding:10px 18px; border-radius:100px; border:1px solid var(--border-strong); font-size:0.85rem; color:var(--gold-light); background:rgba(201,162,76,0.06);}
  .chip .icon{width:15px; height:15px;}

  @media (max-width:860px){
    .about-grid{grid-template-columns:1fr; gap:36px;}
    .about-frame{max-width:340px; margin:0 auto; aspect-ratio:1/1;}
  }

  /* ---------- Divider glyph ---------- */
  .kundali-divider{display:flex; align-items:center; gap:14px; margin:0 auto 56px; max-width:220px;}
  .kundali-divider .line{flex:1; height:1px; background:linear-gradient(90deg, transparent, var(--border-strong));}
  .kundali-divider .line.rev{background:linear-gradient(90deg, var(--border-strong), transparent);}
  .kundali-divider .diamond{width:9px; height:9px; border:1px solid var(--gold); transform:rotate(45deg); flex:none;}

  /* ---------- Services (main) ---------- */
  .alt-bg{background:var(--bg-alt); border-top:1px solid var(--border); border-bottom:1px solid var(--border);}
  .services-grid{display:grid; grid-template-columns:repeat(3, 1fr); gap:26px;}
  .service-card{
    background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-md);
    padding:34px 30px; transition:transform .3s ease, border-color .3s ease, box-shadow .3s ease;
    display:flex; flex-direction:column; gap:16px;
  }
  .service-card:hover{transform:translateY(-6px); border-color:var(--border-strong); box-shadow:var(--shadow);}
  .service-icon{width:52px; height:52px; border-radius:14px; background:linear-gradient(155deg, rgba(201,162,76,0.16), rgba(177,75,92,0.12)); border:1px solid var(--border-strong); display:flex; align-items:center; justify-content:center; color:var(--gold-light);}
  .service-icon .icon{width:24px; height:24px;}
  .service-card h3{font-size:1.32rem; font-weight:600;}
  .service-card p{color:var(--ink-soft); font-size:0.96rem; flex:1;}
  .service-card .card-link{display:inline-flex; align-items:center; gap:6px; font-size:0.85rem; font-weight:600; color:var(--gold-light); margin-top:4px;}

  @media (max-width:960px){ .services-grid{grid-template-columns:repeat(2,1fr);} }
  @media (max-width:620px){ .services-grid{grid-template-columns:1fr;} }

  /* ---------- More services ---------- */
  .more-grid{display:grid; grid-template-columns:repeat(4, 1fr); gap:16px;}
  .more-card{
    padding:24px 22px; border:1px solid var(--border); border-radius:var(--radius-sm);
    background:var(--surface); transition:border-color .25s ease, transform .25s ease;
    display:flex; align-items:center; gap:12px;
  }
  .more-card:hover{border-color:var(--border-strong); transform:translateY(-3px);}
  .more-card .dot{width:7px; height:7px; background:var(--rose-light); border-radius:2px; transform:rotate(45deg); flex:none;}
  .more-card span{font-size:0.94rem; font-weight:500; color:var(--ink);}

  @media (max-width:960px){ .more-grid{grid-template-columns:repeat(2,1fr);} }

  /* ---------- Why choose us ---------- */
  .why-grid{display:grid; grid-template-columns:repeat(3, 1fr); gap:30px 34px;}
  .why-item{display:flex; gap:18px;}
  .why-icon{width:48px; height:48px; border-radius:12px; background:rgba(177,75,92,0.14); border:1px solid var(--border); color:var(--rose-light); display:flex; align-items:center; justify-content:center; flex:none;}
  .why-icon .icon{width:22px; height:22px;}
  .why-item h4{font-size:1.1rem; font-weight:600; margin-bottom:6px;}
  .why-item p{color:var(--ink-soft); font-size:0.93rem;}

  @media (max-width:900px){ .why-grid{grid-template-columns:repeat(2,1fr);} }
  @media (max-width:560px){ .why-grid{grid-template-columns:1fr;} }

  /* ---------- Testimonials ---------- */
  .testi-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:26px;}
  .testi-card{background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-md); padding:32px 28px; display:flex; flex-direction:column; gap:18px;}
  .testi-card .quote-icon{color:var(--gold-dim); width:30px; height:30px;}
  .testi-card p.quote{font-family:var(--font-display); font-style:italic; font-size:1.14rem; line-height:1.55; color:var(--ink);}
  .testi-stars{display:flex; gap:4px; color:var(--gold);}
  .testi-stars .icon{width:15px; height:15px;}
  .testi-person{display:flex; flex-direction:column; margin-top:auto;}
  .testi-person .name{font-weight:600; color:var(--ink);}
  .testi-person .loc{font-size:0.82rem; color:var(--ink-faint);}

  @media (max-width:900px){ .testi-grid{grid-template-columns:1fr;} }

  /* ---------- FAQ ---------- */
  .faq-list{max-width:820px; margin:0 auto;}
  .faq-item{border-bottom:1px solid var(--border);}
  .faq-q{width:100%; display:flex; align-items:center; justify-content:space-between; gap:20px; background:none; border:none; text-align:left; cursor:pointer; padding:24px 4px; font-family:var(--font-body); font-size:1.03rem; font-weight:600; color:var(--ink);}
  .faq-q .icon{color:var(--gold-light); width:19px; height:19px; flex:none; transition:transform .3s ease;}
  .faq-item.open .faq-q .icon{transform:rotate(180deg);}
  .faq-a{max-height:0; overflow:hidden; transition:max-height .35s ease;}
  .faq-a p{padding:0 4px 26px; color:var(--ink-soft); font-size:0.97rem; max-width:700px;}

  /* ---------- CTA banner ---------- */
  .cta-banner{
    background:linear-gradient(135deg, var(--surface-2), var(--surface));
    border:1px solid var(--border-strong); border-radius:var(--radius-lg);
    padding:56px 48px; display:flex; align-items:center; justify-content:space-between; gap:30px; flex-wrap:wrap;
  }
  .cta-banner h3{font-size:clamp(1.5rem, 1.6vw + 1rem, 2.1rem); max-width:520px;}
  .cta-banner p{color:var(--ink-soft); margin-top:10px;}
  .cta-actions{display:flex; gap:14px; flex-wrap:wrap;}

  /* ---------- Footer ---------- */
  footer{background:var(--bg-alt); border-top:1px solid var(--border); padding:80px 0 0;}
  .footer-grid{display:grid; grid-template-columns:1.3fr 1fr 1fr 1.2fr; gap:40px; padding-bottom:56px; border-bottom:1px solid var(--border);}
  .footer-brand .logo{margin-bottom:14px;}
  .footer-brand p{color:var(--ink-soft); font-size:0.93rem; max-width:280px;}
  .footer-col h5{font-size:0.82rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--gold-light); font-weight:600; margin-bottom:18px;}
  .footer-col a, .footer-col li{display:block; color:var(--ink-soft); font-size:0.93rem; margin-bottom:12px; transition:color .2s ease;}
  .footer-col a:hover{color:var(--gold-light);}
  .contact-line{display:flex; align-items:flex-start; gap:10px; margin-bottom:14px;}
  .contact-line .icon{width:16px; height:16px; color:var(--gold-light); margin-top:3px; flex:none;}
  .footer-bottom{display:flex; align-items:center; justify-content:space-between; gap:20px; padding:26px 0; flex-wrap:wrap;}
  .footer-bottom p{font-size:0.82rem; color:var(--ink-faint);}
  .disclaimer{font-size:0.78rem; color:var(--ink-faint); max-width:640px; line-height:1.6;}

  @media (max-width:860px){
    .footer-grid{grid-template-columns:1fr 1fr; gap:36px 24px;}
  }
  @media (max-width:560px){
    .footer-grid{grid-template-columns:1fr;}
    .cta-banner{padding:40px 26px;}
  }

  /* ---------- Floating WhatsApp/Call button ---------- */
  .float-cta{
    position:fixed; right:22px; bottom:22px; z-index:90;
    display:flex; align-items:center; gap:10px; padding:14px 22px;
    background:linear-gradient(135deg, var(--gold-light), var(--gold)); color:#1A1009;
    border-radius:100px; font-weight:600; font-size:0.9rem; box-shadow:0 16px 34px rgba(0,0,0,0.4);
    transition:transform .25s ease;
  }
  .float-cta:hover{transform:translateY(-3px);}
  .float-cta .icon{width:18px; height:18px;}

  /* ---------- Scroll reveal ---------- */
  .reveal{opacity:0; transform:translateY(22px); transition:opacity .7s ease, transform .7s ease;}
  .reveal.in{opacity:1; transform:translateY(0);}

  /* ---------- Focus states ---------- */
  a:focus-visible, button:focus-visible{outline:2px solid var(--gold-light); outline-offset:3px; border-radius:4px;}
</style>
</head>
